BOT_TOKEN=123456:replace-me

# Option 1: Multi-channel config (recommended)
# JSON array of channel configurations. Each channel is independent.
# CHANNELS_JSON='[{"slug":"pisma2","channel_id":-100...,"discussion_group_id":-100...,"name":"Общество писем 2","invite_link_name":"pisma2-main","private_commands":false},{"slug":"walks","channel_id":-100...,"discussion_group_id":-100...,"name":"The Walks","invite_link_name":"walks-main","private_commands":true}]'

# Option 2: Legacy single-channel config (fallback if CHANNELS_JSON is not set)
CHANNEL_ID=-1001234567890
DISCUSSION_GROUP_ID=-1009876543210
# Optional: send warnings to a different chat than the discussion group.
# REMINDER_CHAT_ID=-1001234567890

WEBAPP_URL=https://your-domain.example
DB_PATH=data/writebot.db
PORT=8080
TZ=Asia/Jerusalem
INITIAL_ADMIN_ID=123456789
BOT_INVITE_LINK_NAME=writebot-main
# Optional comma-separated fallback bootstrap for already existing members.
# MANUAL_MEMBER_IDS=111111111,222222222
